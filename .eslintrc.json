{
  "extends": "next/core-web-vitals",
  "rules": {
    "no-console": "warn",
    "@typescript-eslint/no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "no-debugger": "error",
    "eqeqeq": ["error", "always"],
    "curly": "error",
    "prefer-const": "error",
    "no-var": "error"
  }
}
