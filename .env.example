# Negoti8 Environment Variables
# Copy this to .env.local and fill in your API keys
# NEVER commit .env.local — it's gitignored

# Groq API (for Whisper STT + Llama 3.3 AI)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Anam.ai (AI Talking Avatar — real-time lip sync)
ANAM_API_KEY=your_anam_api_key_here

# ElevenLabs (for Text-to-Speech)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Supabase (for Auth + Database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Cloudflare R2 (for audio/avatar storage)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=negoti8-media
