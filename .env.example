# Negotia8 — Environment Variables
# Copy to .env.local and fill in your keys

# Groq API (required) — https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Anam AI Avatar (optional) — https://anam.ai
# If not set, falls back to SVG emotion face avatar
ANAM_API_KEY=

# SadTalker (optional) — local talking avatar server
# Only needed if running a local SadTalker instance
SADTALKER_URL=http://localhost:8765
